# Copy this file to .env at the project root before running docker compose.
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=cloud_ai_platform
MYSQL_USER=cloudai
MYSQL_PASSWORD=cloudai_password
SECRET_KEY=please-change-this-to-a-random-64-char-secret-in-production
CLOUD_CREDENTIALS_ENCRYPTION_KEY=please-change-this-to-a-different-random-secret-in-production
CORS_ORIGINS=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Alerting (see docs/PHASE_5.md)
ALERT_EVALUATION_INTERVAL_MINUTES=5
# Leave the following blank to disable that channel (falls back to logging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
