# Application
APP_NAME=Cloud AI Platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=cloudai
MYSQL_PASSWORD=cloudai_password
MYSQL_DATABASE=cloud_ai_platform
MYSQL_ROOT_PASSWORD=root_password

# Separate database (same MySQL server) for login credentials only (see docs/PHASE_13.md)
AUTH_MYSQL_DATABASE=cloud_ai_auth

# JWT
SECRET_KEY=please-change-this-to-a-random-64-char-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloud provider account credential encryption (deliberately separate from
# SECRET_KEY - see app/utils/crypto.py)
CLOUD_CREDENTIALS_ENCRYPTION_KEY=please-change-this-to-a-different-random-secret-in-production

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=10/hour

# Real-time cloud metrics sync (see docs/PHASE_12.md)
CLOUD_SYNC_INTERVAL_MINUTES=15
CLOUD_SYNC_LOOKBACK_MINUTES=15
